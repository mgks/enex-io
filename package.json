{
  "name": "enex-io",
  "version": "0.3.4",
  "description": "High-performance parser and generator for Evernote/Apple Notes (.enex) files.",
  "type": "module",
  "bin": {
    "enex-io": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "scripts": {
    "test": "node --import=tsx --test test/*.test.mjs",
    "build": "tsup",
    "prepublishOnly": "npm run build && npm test",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "fs",
    "converter",
    "enex",
    "evernote",
    "apple-notes",
    "parser",
    "xml"
  ],
  "author": {
    "name": "mgks",
    "url": "https://mgks.dev"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgks/enex-io.git"
  },
  "bugs": {
    "url": "https://github.com/mgks/enex-io/issues"
  },
  "homepage": "https://github.com/mgks/enex-io#readme",
  "funding": "https://github.com/sponsors/mgks",
  "dependencies": {
    "cheerio": "^1.2.0",
    "commander": "^11.1.0",
    "dayjs": "^1.11.20"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
